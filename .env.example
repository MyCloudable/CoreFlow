# Copy to .env for local development. In production, set these in your host's
# environment settings instead (never commit real secrets).

# --- Database ---------------------------------------------------------------
# Local dev (SQLite, zero setup):
DATABASE_URL="file:./dev.db"
# Production (Postgres — also change provider to "postgresql" in
# prisma/schema.prisma; see DEPLOYMENT.md):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Hosting ----------------------------------------------------------------
# The apex host the platform runs on. Tenant portals live at <slug>.<ROOT_DOMAIN>.
# Local: "localhost:3000". Production: "yourdomain.com" (no protocol, include a
# port only if you serve on a non-standard one).
ROOT_DOMAIN="localhost:3000"

# --- Stripe (optional until you're ready to charge) --------------------------
# Billing activates ONLY when all four are set; otherwise the app no-ops Stripe
# and you manage tenants manually from /admin. See DEPLOYMENT.md "Stripe".
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASE=""
STRIPE_PRICE_SEAT=""
